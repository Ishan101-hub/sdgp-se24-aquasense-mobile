# AquaSense Backend Environment Variables
# Copy this file to backend/.env for local development.
# Do NOT commit real credentials.

ENVIRONMENT=production
CORS_ALLOWED_ORIGINS=https://aquasense-sdgp.web.app

# Database
DATABASE_URL=postgresql+asyncpg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# JWT
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email / OTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Encryption
ENCRYPTION_KEY=replace-with-fernet-key

# MQTT / HiveMQ
MQTT_BROKER_HOST=your-hivemq-host.s1.eu.hivemq.cloud
MQTT_BROKER_PORT=8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_CLIENT_ID=aquasense-backend

# Batch writer
INSERT_BATCH_SIZE=50
INSERT_BATCH_FLUSH_SECONDS=5

# Leak detection
FLOW_MISMATCH_THRESHOLD_LPM=0.8
LEAK_CONFIRM_COUNT=3
HEARTBEAT_TIMEOUT_SEC=5.0
HIGH_FLOW_THRESHOLD_LPM=15.0
HIGH_FLOW_DURATION_SEC=300
BURST_FLOW_THRESHOLD_LPM=50.0
VALVE_STUCK_FLOW_THRESHOLD_LPM=0.5
VALVE_STUCK_CHECK_DELAY_SEC=3
LEAK_FLOW_THRESHOLD_LPM=25.0
LEAK_SEVERITY_MEDIUM=25.0
LEAK_SEVERITY_HIGH=40.0
AUTO_CLOSE_VALVE_ON_HIGH=true
